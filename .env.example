# =============================================================================
# ScholarRAG environment configuration file
# Copy this file as .env and modify the configuration according to your environment
# cp .env.example .env
# =============================================================================

# =============================================================================
# LLM API Configuration (OpenAI compatible)
# =============================================================================

# OpenAI Compatible API base address
# Use local vLLM: http://localhost:8000/v1
# use OpenAI: https://api.openai.com/v1
# use Moonshot: https://api.moonshot.cn/v1
OPENAI_API_BASE=http://localhost:8000/v1

# API key
# Local vLLM usually does not require a key and can be left blank
# OpenAI: sk-...
# Moonshot: sk-...
OPENAI_API_KEY=

# LLM Model name
# local vLLM: Use the name of the model you loaded
# OpenAI: gpt-4, gpt-3.5-turbo
# Moonshot: moonshot-v1-8k, Pro/moonshotai/Kimi-K2.5
LLM_MODEL=Pro/moonshotai/Kimi-K2.5

# =============================================================================
# Embed model configuration (Qwen3-VL)
# =============================================================================

# Local Qwen3-VL embedded model path
# Relative path (relative to project root) or absolute path
# Model download: https://huggingface.co/Qwen/Qwen3-VL-Embedding-2B
EMBEDDING_MODEL=models/Qwen3-VL-Embedding-2B

# =============================================================================
# Vector database configuration (Qdrant)
# =============================================================================

# Qdrant Service address
QDRANT_HOST=localhost

# Qdrant service port
QDRANT_PORT=6333

# Qdrant Collection name (used to store papers chunks）
QDRANT_COLLECTION_NAME=papers_rag

# =============================================================================
# PDF Parse configuration (MinerU)
# =============================================================================

# MinerU Model source
# - modelscope: Download from ModelScope (recommended, fast in China）
# - huggingface: Download from HuggingFace
# - local: Use a locally downloaded model
MINERU_MODEL_SOURCE=modelscope

# MinerU backend engine
# - pipeline: Complete pipeline (default, high accuracy）
# - hybrid-auto-engine: Hybrid engine (fast）
MINERU_BACKEND=pipeline

# =============================================================================
# RAG Retrieve configuration
# =============================================================================

# Retrieve the number of top-k chunks returned
# Larger values ​​give the LLM more context, but may introduce noise
RAG_TOP_K=5

# similarity threshold (0.0 - 1.0)
# Chunks below this threshold will be filtered
# 0.0 Indicates no filtering
SCORE_THRESHOLD=0.3

# Whether to enable hybrid retrieval (dense vector + BM25 sparse vector）
# Requires installation: pip install fastembed
# true | false
ENABLE_HYBRID=false

# =============================================================================
# Agent Configuration
# =============================================================================

# Agent Maximum number of iterations
# Prevent infinite loops and force stop after reaching this number of times
AGENT_MAX_ITERATIONS=10

# =============================================================================
# Storage path configuration
# =============================================================================

# PDF File storage directory (for PDF reader function）
PDF_STORAGE_DIR=./data/pdfs

# MinerU parse output directory
PARSED_OUTPUT_DIR=./data/parsed

# Temporary storage directory for uploaded files
API_UPLOAD_DIR=./data/uploads

# SQLite Database path (task and version management）
# By default, SQLite files in memory or project directory are used.
# DATABASE_URL=sqlite+aiosqlite:///./data/scholarrag.db

# =============================================================================
# API Service configuration (FastAPI)
# =============================================================================

# API Service listening address
API_HOST=0.0.0.0

# API service port
API_PORT=8000

# =============================================================================
# Evaluation configuration (optional）
# =============================================================================

# Evaluate dataset path
# EVAL_DATASET=tests/evaluation/dataset.json

# Evaluation report output directory
# EVAL_OUTPUT_DIR=./reports

# =============================================================================
# Development configuration (optional）
# =============================================================================

# Log level: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO

# Whether to enable debugging mode
# DEBUG=false
